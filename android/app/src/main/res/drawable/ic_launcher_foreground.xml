<?xml version="1.0" encoding="utf-8"?>
<!--
    FANDEX-App 启动图标 - 前景层

    设计语言：经典蓝色背景 + 白色 F 字母
    - 蓝色背景 #4F5BD5 填满 108x108
    - 白色竖线 + 白色横线构成 F 字母

    自适应图标安全区域：中心 72x72dp（108dp 画布）
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 蓝色背景填满画布 -->
    <path
        android:fillColor="#4F5BD5"
        android:pathData="M0,0h108v108h-108z"/>

    <!-- F 字母：左侧竖线 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,32h8v44h-8z"/>

    <!-- F 字母：右侧竖线 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M62,32h8v44h-8z"/>

    <!-- F 字母：中间横线 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,52h32v8h-32z"/>

</vector>
