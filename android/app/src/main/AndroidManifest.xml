<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FANDEX"
        android:usesCleartextTraffic="false">

        <!-- 启动页 Activity（LAUNCHER 入口） -->
        <activity
            android:name=".home.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.FANDEX">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 主页 Activity（非 LAUNCHER，由 SplashActivity 跳转） -->
        <activity
            android:name=".home.HomeActivity"
            android:exported="true"
            android:theme="@style/Theme.FANDEX" />

        <!-- 默认图标（新图标：深色 + 竖色条 + FANDEX） -->
        <activity-alias
            android:name=".home.HomeActivityDefault"
            android:targetActivity=".home.HomeActivity"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name">
        </activity-alias>

        <!-- 经典图标（旧图标：蓝色 + F 字母） -->
        <activity-alias
            android:name=".home.HomeActivityClassic"
            android:targetActivity=".home.HomeActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_classic"
            android:label="@string/app_name">
        </activity-alias>

    </application>

</manifest>
